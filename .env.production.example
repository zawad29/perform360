DATABASE_URL=postgresql://USER:PASSWORD@DB_HOST:5432/performs360?schema=public

NEXTAUTH_SECRET=replace-with-a-strong-random-secret
NEXTAUTH_URL=https://app.example.com
NEXT_PUBLIC_APP_URL=https://app.example.com

# Email provider: resend | brevo | mailgun | smtp
EMAIL_PROVIDER=brevo

# Resend (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Brevo (if EMAIL_PROVIDER=brevo)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx

# Mailgun (if EMAIL_PROVIDER=mailgun)
MAILGUN_API_KEY=key-xxxxxxxxxxxx
MAILGUN_DOMAIN=mg.yourdomain.com
# EU region only: MAILGUN_API_URL=https://api.eu.mailgun.net

# SMTP (if EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

EMAIL_FROM="Performs360 <noreply@performs360.com>"
