// ─────────────────────────────────────────────────────────
// Performs360 — Self-Hosted 360 Performance Evaluation Platform
// Prisma Schema
// ─────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// NextAuth.js Models (Auth.js v5 Adapter Compatibility)
// ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthUser {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  @@map("auth_users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────
// EVALUATION TEMPLATES
// ─────────────────────────────────────────────────────────

enum Direction {
  DOWNWARD
  UPWARD
  LATERAL
  SELF
  EXTERNAL
}

enum WeightPreset {
  equal
  supervisor_focus
  peer_focus
  custom
}

model EvaluationTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Bumps on every PATCH. Past iterations are preserved in
  // `EvaluationTemplateVersion` so admins can view and restore prior versions.
  version Int @default(1)

  // Template-wide level filter. Empty array = applies to all levels.
  levelIds String[] @default([])

  // Direction weights (optional). null = equal/default at scoring time.
  // Shape: { downward, upward, lateral, self, external } as decimals 0.0–1.0
  weightPreset   WeightPreset?
  weightsMember  Json?
  weightsManager Json?

  // Sections JSON: array of
  //   { id, title, description?, directions: Direction[], questions: [...] }
  // directions = [] means "all directions"
  sections Json

  isGlobal   Boolean  @default(false)
  isArchived Boolean  @default(false)
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cycleTeamTemplates CycleTeamTemplate[]
  versions           EvaluationTemplateVersion[]
}

// Append-only audit trail of template content. One row per version (so v1 is
// the initial save, v2 is after the first edit, and so on). The current
// content also lives on `EvaluationTemplate` itself for fast reads — the
// version table is the historical record.
model EvaluationTemplateVersion {
  id             String             @id @default(cuid())
  templateId     String
  template       EvaluationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version        Int
  name           String
  description    String?
  levelIds       String[]           @default([])
  weightPreset   WeightPreset?
  weightsMember  Json?
  weightsManager Json?
  sections       Json
  createdBy      String
  createdAt      DateTime           @default(now())

  @@unique([templateId, version])
  @@index([templateId])
}

// ─────────────────────────────────────────────────────────
// COMPANY (Singleton — one per self-hosted instance)
// ─────────────────────────────────────────────────────────

model Company {
  id   String  @id @default(cuid())
  name String
  slug String  @unique
  logo String?

  settings Json?

  // Encryption (company-owned keys)
  encryptionKeyEncrypted String
  encryptionSalt         String? // base64-encoded salt for scrypt key derivation
  encryptionSetupAt      DateTime? // null = setup not complete, timestamp = setup done
  keyVersion             Int       @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users         User[]
  teams         Team[]
  cycles        EvaluationCycle[]
  templates     EvaluationTemplate[]
  recoveryCodes RecoveryCode[]
  auditLogs     AuditLog[]
  levels        Level[]
}

enum UserRole {
  ADMIN
  HR
  MEMBER
  EXTERNAL
}

model User {
  id         String    @id @default(cuid())
  email      String
  name       String
  avatar     String?
  role       UserRole  @default(MEMBER)
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  authUserId String? // Links to AuthUser for NextAuth session resolution
  createdAt  DateTime  @default(now())
  archivedAt DateTime? // null = active, set = archived (soft delete)

  // Relations
  teamMemberships  TeamMember[]
  submittedReviews EvaluationResponse[]
  receivedReviews  EvaluationResponse[] @relation("ReviewSubject")

  // Calibration relations
  calibrationsReceived  CalibrationAdjustment[] @relation("CalibrationSubject")
  calibrationsPerformed CalibrationAdjustment[] @relation("CalibrationAdjuster")

  @@unique([email, companyId])
  @@index([authUserId])
}

// ─────────────────────────────────────────────────────────
// TEAMS
// ─────────────────────────────────────────────────────────

model Team {
  id          String    @id @default(cuid())
  name        String
  description String?
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?

  members      TeamMember[]
  cycleTeams   CycleTeam[]
  calibrations CalibrationAdjustment[]
}

enum TeamMemberRole {
  MANAGER
  MEMBER
  EXTERNAL
  IMPERSONATOR
}

model TeamMember {
  id                     String         @id @default(cuid())
  userId                 String
  teamId                 String
  role                   TeamMemberRole
  levelId                String?
  impersonatorDirections Direction[]    @default([])

  user  User   @relation(fields: [userId], references: [id])
  team  Team   @relation(fields: [teamId], references: [id])
  level Level? @relation(fields: [levelId], references: [id], onUpdate: Cascade, onDelete: SetNull)

  @@unique([userId, teamId])
  @@index([userId])
}

model Level {
  id        String   @id @default(cuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())

  teamMembers TeamMember[]

  @@unique([companyId, name])
}

// ─────────────────────────────────────────────────────────
// EVALUATION CYCLES
// ─────────────────────────────────────────────────────────

enum CycleStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

model EvaluationCycle {
  id        String      @id @default(cuid())
  name      String
  companyId String
  company   Company     @relation(fields: [companyId], references: [id])
  status    CycleStatus @default(DRAFT)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Cached data key (encrypted with NEXTAUTH_SECRET) — set on activation,
  // allows submission route to encrypt reviewer answers without the passphrase.
  cachedDataKeyEncrypted String?

  assignments   EvaluationAssignment[]
  cycleTeams    CycleTeam[]
  reviewerLinks CycleReviewerLink[]
  calibrations  CalibrationAdjustment[]

  @@index([companyId, status])
}

model CycleTeam {
  id        String          @id @default(cuid())
  cycleId   String
  cycle     EvaluationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team            @relation(fields: [teamId], references: [id])
  createdAt DateTime        @default(now())

  templates CycleTeamTemplate[]

  // Team-level calibration offset (e.g., -0.5 for lenient teams, +0.3 for strict)
  // Applied to all members' scores; null = no team-level adjustment
  calibrationOffset        Float?
  calibrationJustification String? @db.Text
  calibrationAdjustedBy    String?

  @@unique([cycleId, teamId])
}

model CycleTeamTemplate {
  id          String             @id @default(cuid())
  cycleTeamId String
  cycleTeam   CycleTeam          @relation(fields: [cycleTeamId], references: [id], onDelete: Cascade)
  templateId  String
  template    EvaluationTemplate @relation(fields: [templateId], references: [id])

  @@unique([cycleTeamId, templateId])
  @@index([cycleTeamId])
  @@index([templateId])
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
}

model EvaluationAssignment {
  id         String           @id @default(cuid())
  cycleId    String
  cycle      EvaluationCycle  @relation(fields: [cycleId], references: [id])
  templateId String
  subjectId  String
  reviewerId String
  direction  Direction
  status     AssignmentStatus @default(PENDING)
  token      String           @unique @default(cuid())
  createdAt  DateTime         @default(now())

  responses   EvaluationResponse[]
  otpSessions OtpSession[]

  @@unique([cycleId, subjectId, reviewerId, templateId, direction])
  @@index([cycleId, status])
  @@index([cycleId, subjectId])
  @@index([reviewerId])
  @@index([templateId])
}

// ─────────────────────────────────────────────────────────
// CYCLE REVIEWER LINKS (Summary access per reviewer per cycle)
// ─────────────────────────────────────────────────────────

model CycleReviewerLink {
  id         String          @id @default(cuid())
  cycleId    String
  cycle      EvaluationCycle @relation(fields: [cycleId], references: [id])
  reviewerId String
  token      String          @unique @default(cuid())
  createdAt  DateTime        @default(now())

  otpSessions OtpSession[]

  @@unique([cycleId, reviewerId])
}

// ─────────────────────────────────────────────────────────
// OTP AUTHENTICATION
// ─────────────────────────────────────────────────────────

model OtpSession {
  id             String                @id @default(cuid())
  assignmentId   String?
  assignment     EvaluationAssignment? @relation(fields: [assignmentId], references: [id])
  reviewerLinkId String?
  reviewerLink   CycleReviewerLink?    @relation(fields: [reviewerLinkId], references: [id])
  email          String
  otpHash        String
  attempts       Int                   @default(0)
  expiresAt      DateTime
  cooldownUntil  DateTime?
  verifiedAt     DateTime?
  sessionToken   String?               @unique
  sessionExpiry  DateTime?
  createdAt      DateTime              @default(now())

  @@index([assignmentId])
  @@index([reviewerLinkId])
}

// ─────────────────────────────────────────────────────────
// EVALUATION RESPONSES (Encrypted)
// ─────────────────────────────────────────────────────────

model EvaluationResponse {
  id           String               @id @default(cuid())
  assignmentId String
  assignment   EvaluationAssignment @relation(fields: [assignmentId], references: [id])
  reviewerId   String
  reviewer     User                 @relation(fields: [reviewerId], references: [id])
  subjectId    String
  subject      User                 @relation("ReviewSubject", fields: [subjectId], references: [id])

  // Encrypted data (AES-256-GCM)
  answersEncrypted String
  answersIv        String
  answersTag       String
  keyVersion       Int

  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([subjectId])
  @@index([assignmentId])
}

// ─────────────────────────────────────────────────────────
// RECOVERY CODES (Encryption Key Recovery)
// ─────────────────────────────────────────────────────────

model RecoveryCode {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])
  codeHash         String // bcrypt hash of the recovery code
  encryptedDataKey String // data key encrypted with scrypt(code, salt)
  usedAt           DateTime? // null = available, timestamp = consumed
  createdAt        DateTime  @default(now())

  @@index([companyId])
}

// ─────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String? // null for system events
  action    String // e.g., "decryption", "role_change", "user_invite", "cycle_activate"
  target    String? // e.g., "user:cuid123", "cycle:cuid456"
  metadata  Json? // Additional context
  ip        String?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────
// CALIBRATION (Post-evaluation score adjustments)
// ─────────────────────────────────────────────────────────

model CalibrationAdjustment {
  id              String          @id @default(cuid())
  cycleId         String
  cycle           EvaluationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  teamId          String
  team            Team            @relation(fields: [teamId], references: [id])
  subjectId       String
  subject         User            @relation("CalibrationSubject", fields: [subjectId], references: [id])
  adjustedBy      String
  adjuster        User            @relation("CalibrationAdjuster", fields: [adjustedBy], references: [id])
  rawScore        Float
  calibratedScore Float
  justification   String          @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([cycleId, teamId, subjectId])
  @@index([cycleId])
}

// ─────────────────────────────────────────────────────────
// JOB QUEUE (Postgres-backed async task processing)
// ─────────────────────────────────────────────────────────

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  DEAD
}

model JobQueue {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      JobStatus @default(PENDING)
  priority    Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lastError   String?
  runAt       DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt, priority])
  @@index([type, status])
  @@index([createdAt])
}
